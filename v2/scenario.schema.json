{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/graphanov/2000m/v2/scenario.schema.json",
  "title": "2000m v2 scenario",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "scenarioId",
    "scenarioVersion",
    "title",
    "baseTrack",
    "phases",
    "scoring"
  ],
  "properties": {
    "schemaVersion": {
      "const": "2000m.v2.scenario.v1"
    },
    "scenarioId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,80}$"
    },
    "scenarioVersion": {
      "type": "integer",
      "minimum": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "baseTrack": {
      "type": "string",
      "enum": ["v1-artifact-score", "v2-native-artifact-score"]
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/phase"
      }
    },
    "scoring": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifactQualityWeight",
        "feedbackIntegrationWeight",
        "recoveryHandoffWeight",
        "stopConditionWeight",
        "evidenceReplayWeight"
      ],
      "properties": {
        "artifactQualityWeight": { "type": "number", "minimum": 0, "maximum": 1 },
        "feedbackIntegrationWeight": { "type": "number", "minimum": 0, "maximum": 1 },
        "recoveryHandoffWeight": { "type": "number", "minimum": 0, "maximum": 1 },
        "stopConditionWeight": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidenceReplayWeight": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "neutralityRules": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phaseId", "kind", "prompt", "requiredOutputs"],
      "properties": {
        "phaseId": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,80}$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "initial-build",
            "scorer-feedback",
            "reviewer-feedback",
            "context-wipe-recovery",
            "requirement-trap",
            "stop-decision"
          ]
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "allowedInputs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "requiredOutputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "artifact-ref",
              "build-command",
              "score-command",
              "conformance-json",
              "feedback-response",
              "handoff-summary",
              "stop-recommendation",
              "evidence-ref"
            ]
          }
        },
        "trapType": {
          "type": "string",
          "enum": ["none", "impossible", "stale", "probe-only"]
        }
      }
    }
  }
}
