{
  "schemaVersion": "2000m.v3.manifest.v1",
  "protocolVersion": "2000m.driver.v3",
  "language": "rust",
  "driver": {
    "command": "cargo",
    "args": [
      "run",
      "--quiet",
      "--bin",
      "driver"
    ],
    "timeoutSeconds": 30
  },
  "capture": {
    "command": "cargo",
    "args": [
      "run",
      "--quiet",
      "--bin",
      "capture",
      "--",
      "--seed",
      "{seed}",
      "--window",
      "{window}",
      "--out",
      "{out}"
    ],
    "outputs": {
      "screenshot": "{out}/screenshot.png",
      "replay": "{out}/replay.gif",
      "frames": "{out}/frames.json",
      "rubricMetadata": "{out}/rubric-metadata.json"
    },
    "metadata": {
      "placeholders": [
        "{seed}",
        "{window}",
        "{out}"
      ],
      "deterministicForSameSeedWindowAndArtifact": true
    }
  },
  "playable": {
    "command": "cargo",
    "args": [
      "run",
      "--quiet",
      "--bin",
      "game"
    ],
    "urlOrPath": "file://local-only/private-build/index.html"
  },
  "assets": {
    "license": "original-homage-assets-only",
    "attestation": "No copied or extracted SkiFree assets are included.",
    "sourceRefs": []
  },
  "notes": "Foundation fixture; not a live contender."
}
