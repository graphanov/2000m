    {"fixtureId": "wrong-feedback-routing", "kind": "wrong-feedback-routing", "runRecordRef": "v3/examples/workflow/run-records/wrong-feedback-routing.run-record.json", "resultRef": "v3/examples/workflow/results/wrong-feedback-routing.result.json", "expected": "Wrong routing lowers workflow.feedbackDecisionScore only."},
